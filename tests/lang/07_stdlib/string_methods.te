// expect: len=11 up=HELLO WORLD low=hello world trim=hi has=1 no=0
// Core string methods: length, upper, lower, trim, contains.
var s = "Hello World";
println("len=" + s.length
      + " up=" + s.upper()
      + " low=" + s.lower()
      + " trim=" + "  hi  ".trim()
      + " has=" + s.contains("World")
      + " no=" + s.contains("xyz"));
