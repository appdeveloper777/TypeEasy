// Gotcha #2: for-in ahora acepta una llamada a metodo inline que devuelve
// una lista (antes habia que hacer `let tmp = ...;` primero).
let a = [1, 2, 3];
let b = [3, 4, 5];
var total = 0;
for (let x in a.union(b)) { total = total + x; }
println(total);   // union distinct = [1,2,3,4,5] -> 15

let nums = [1, 2, 3, 4, 5, 6];
var c = 0;
for (let x in nums.where(n => n > 3)) { c = c + 1; }
println(c);       // [4,5,6] -> 3
