// Copia de una variable a otra con identificador desnudo (let b = a).
// Regresión: antes el identificador puro caía al catch-all y se guardaba
// como INT 0. Debe copiar el valor real (int/float/string) y ser independiente.
// expect: i=2 s=hola f=3.500000 indep=1 a2=99 while=2|3|4|
var out = "";

let vi = 2;
let ci = vi;
out = out + "i=" + ci + " ";

let vs = "hola";
let cs = vs;
out = out + "s=" + cs + " ";

let vf = 3.5;
let cf = vf;
out = out + "f=" + cf + " ";

// la copia es independiente: reasignar el origen no altera el destino
var a = 1;
var b = a;
a = 99;
out = out + "indep=" + b + " ";
out = out + "a2=" + a + " ";

// workaround documentado para empezar un conteo desde una variable
let start = 2;
var i = start;
out = out + "while=";
while (i < 5) {
    out = out + i + "|";
    i = i + 1;
}

println(out);
