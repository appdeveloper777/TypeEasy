// expect: 70
// LINQ .where().sumBy() fusion: sum prices of category 'dulce'.
// dulce rows: Chocolate=10, Paneton=25, Galleta=5, Cake=30 => 70

class Producto {
    nombre    : string;
    precio    : int;
    categoria : string;
}

let productos = from "productos.csv", Producto;
println(productos.where(fn(p) => p.categoria == "dulce").sumBy(fn(p) => p.precio));
