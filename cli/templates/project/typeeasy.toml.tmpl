# TypeEasy project manifest
# Generated by: typeeasy new {{PROJECT_NAME}}

[project]
name        = "{{PROJECT_NAME}}"
version     = "0.1.0"
description = "TypeEasy application"

[server]
# Defaults applied when running `typeeasy serve` (overridden by [env.X] below).
apis_dir = "./apis"
host     = "0.0.0.0"
port     = 8080
workers  = 0          # 0 = auto-detect

# --------------------------------------------------------------------------
# Per-environment overrides. Selected by `typeeasy serve --dev` / `--prod`.
# Precedence: CLI flag > [env.X] > [server] > built-in defaults.
# --------------------------------------------------------------------------

[env.dev]
host       = "127.0.0.1"   # bind sólo local
port       = 8080
workers    = 1             # 1 worker = fácil debuggear
hotreload  = true          # recarga .te al cambiar

[env.prod]
host       = "0.0.0.0"     # acepta conexiones externas
port       = 8080
workers    = 0             # 0 = auto (nproc)
hotreload  = false         # zero overhead

[prod]
# Deploy target — used by `typeeasy deploy`
# host       = "vps.example.com"
# user       = "typeeasy"
# remote_dir = "/opt/{{PROJECT_NAME}}"

[database]
# Default DB connection used by generated scaffolds.
driver = "mysql"
host   = "127.0.0.1"
port   = 3306
user   = "typeeasy"
pass   = "typeeasy"
name   = "{{PROJECT_NAME}}"
