# Production environment variables
# Deployed to /etc/default/typeeasy-api@<port> on the server.
TYPEEASY_APIS_DIR=/opt/PROJECT_NAME/apis
TYPEEASY_HOST=127.0.0.1
TYPEEASY_PORT=8080
TYPEEASY_HOTRELOAD=0

# Database (overridden in /etc/default/typeeasy-api.secrets on server)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=typeeasy
DB_PASS=CHANGEME
DB_NAME=prod
