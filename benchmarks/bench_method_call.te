/* Bench: llamadas a método en hot loop (10M iter).
 * Mide overhead de invocación de método + return + parámetros.
 */
class Calc {
    base : int;
    __constructor(_b : int) {
        this.base = _b;
    }
    add(x : int) : int {
        return this.base + x;
    }
}

let c = new Calc(7);
int total = 0;
int r = 0;

for(i = 0; 10000000; 1) {
    r = c.add(3);
    total = total + r;
}

println(total);
