class Punto {
    x : int;
    y : int;
    __constructor(_x : int, _y : int) {
        this.x = _x;
        this.y = _y;
    }
}

let arr = [];
for (i = 0; 100000; 1) {
    arr.push(new Punto(i, i));
}

var total = 0;
// 100 read passes sobre 100k = 10M lookups arr[j].x
for (k = 0; 100; 1) {
    for (j = 0; 100000; 1) {
        total = total + arr[j].x;
    }
}
println(total);
