{
    "version": 4,
    "configurations": [
        {
            "name": "Win32 (MSYS2 MinGW-w64)",
            "compilerPath": "C:/msys64/mingw64/bin/gcc.exe",
            "intelliSenseMode": "windows-gcc-x64",
            "cStandard": "gnu11",
            "cppStandard": "gnu++17",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src",
                "${workspaceFolder}/api_server",
                "C:/msys64/mingw64/include",
                "C:/msys64/mingw64/include/mariadb",
                "C:/msys64/mingw64/include/openssl",
                "C:/msys64/mingw64/lib/gcc/x86_64-w64-mingw32/16.1.0/include",
                "C:/msys64/mingw64/lib/gcc/x86_64-w64-mingw32/16.1.0/include-fixed"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/src",
                    "${workspaceFolder}/api_server",
                    "C:/msys64/mingw64/include"
                ],
                "limitSymbolsToIncludedHeaders": false
            },
            "defines": [
                "_WIN32",
                "__MINGW64__",
                "USE_OPENSSL",
                "NO_SSL_DL",
                "OPENSSL_API_1_1",
                "USE_WEBSOCKET",
                "TE_HAVE_LIBCURL",
                "TE_HAVE_OPENMP",
                "TE_ENABLE_JIT=1",
                "TE_WIN_HAVE_FREETDS",
                "_GNU_SOURCE",
                "_POSIX_C_SOURCE=200809L"
            ]
        },
        {
            "name": "Linux (gcc:13.2 / Docker)",
            "compilerPath": "/usr/bin/gcc",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "gnu11",
            "cppStandard": "gnu++17",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src",
                "${workspaceFolder}/api_server",
                "/usr/include",
                "/usr/include/x86_64-linux-gnu",
                "/usr/include/postgresql",
                "/usr/include/mysql"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/src",
                    "${workspaceFolder}/api_server",
                    "/usr/include"
                ],
                "limitSymbolsToIncludedHeaders": false
            },
            "defines": [
                "USE_OPENSSL",
                "NO_SSL_DL",
                "OPENSSL_API_1_1",
                "USE_WEBSOCKET",
                "TE_HAVE_LIBCURL",
                "TE_HAVE_OPENMP",
                "TE_ENABLE_JIT=1",
                "_GNU_SOURCE",
                "_POSIX_C_SOURCE=200809L"
            ],
            "compileCommands": "${workspaceFolder}/build/compile_commands.json"
        }
    ]
}
