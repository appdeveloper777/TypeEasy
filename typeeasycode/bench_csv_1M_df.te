class Producto {
  nombre : string;
  precio : int;

  __constructor(nombre : string, precio : int) {
    this.nombre = nombre;
    this.precio = precio;
  }
}

// Versión dataframe (path columnar puro, sin construir objetos por fila).
let t0 = now_ms();
let productos = from "productos_10000000.csv", Producto as dataframe;
let t1 = now_ms();
int cantidad = productos.length;
println("filas=" + cantidad);

let t2 = now_ms();
float suma = productos.sum("precio");
let t3 = now_ms();
println("sumBy.precio=" + suma);

println("read_csv=" + (t1 - t0) + "ms");
println("tiempo_sumBy=" + (t3 - t2) + "ms");
println("total=" + (t3 - t0) + "ms");
