// =====================================================
// Ejemplo Dapper-style — MySQL
// Ejecutar: docker compose run --rm typeeasy dapper_mysql.te
// =====================================================

let conn = new mysql_connect("gateway01.us-east-1.prod.aws.tidbcloud.com", "2XCY4FHDYiMMcdi.root", "dMal8ex6FlLgprno", "test", 4000);

// 1) SELECT con parámetros nombrados (@min, @pat)
let r1 = new mysql_query(
    conn,
    "SELECT nombre, precio FROM productos WHERE precio > @min AND nombre LIKE @pat",
    { "@min": 1, "@pat": "%a%" },
    "json"
);
print("[MySQL] productos filtrados:");
println(r1);

// 2) SELECT por id
let r2 = new mysql_query(
    conn,
    "SELECT * FROM productos WHERE id = @id",
    { "@id": 1 },
    "json"
);
print("[MySQL] producto por id:");
println(r2);

// 3) INSERT parametrizado (escape automático de comillas)
let r3 = new mysql_query(
    conn,
    "INSERT INTO productos (nombre, precio) VALUES (@nombre, @precio)",
    { "@nombre": "O'Reilly Book", "@precio": 19.9 }
);
print("[MySQL] insert:");
println(r3);

// 4) UPDATE parametrizado
let r4 = new mysql_query(
    conn,
    "UPDATE productos SET precio = @nuevo WHERE nombre = @nombre",
    { "@nuevo": 25, "@nombre": "O'Reilly Book" }
);
print("[MySQL] update:");
println(r4);

// 5) Usando una clase como contenedor de parámetros
//    (sus atributos se exponen como @id, @nombre, @precio, etc.)
class FiltroProducto {
    id: int;
    nombre: string;
    precio: float;
    __constructor(_id: int, _nombre: string, _precio: float) {
        this.id = _id;
        this.nombre = _nombre;
        this.precio = _precio;
    }
}

let filtro = new FiltroProducto(1, "O'Reilly Book", 19.9);

// SELECT con el objeto: @id, @nombre, @precio salen de los atributos
let r5 = new mysql_query(
    conn,
    "SELECT * FROM productos WHERE id = @id OR nombre = @nombre",
    filtro,
    "json"
);
print("[MySQL] filtro por objeto:");
println(r5);

// 6) INSERT usando el mismo objeto
let r6 = new mysql_query(
    conn,
    "INSERT INTO productos (nombre, precio) VALUES (@nombre, @precio)",
    filtro
);
print("[MySQL] insert por objeto:");
println(r6);

// 7) UPDATE usando el objeto (id como WHERE, los demás como SET)
let r7 = new mysql_query(
    conn,
    "UPDATE productos SET nombre = @nombre, precio = @precio WHERE id = @id",
    filtro
);
print("[MySQL] update por objeto:");
println(r7);

mysql_close(conn);
