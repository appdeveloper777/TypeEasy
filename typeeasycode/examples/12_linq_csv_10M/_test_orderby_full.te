class Producto {
  nombre : string;
  precio : int;
}
let xs = from "/code/productos_1000000.csv", Producto;
println("got=" + xs.length);
let ob = xs.orderBy(fn(p) => p.precio);
println("ob[0]=" + ob[0].precio);
let ob2 = xs.orderByDescending(fn(p) => p.precio);
println("ob2[0]=" + ob2[0].precio);
let gb = xs.groupBy(fn(p) => p.precio % 10);
println("gb.length=" + gb.length);
println("OK");
