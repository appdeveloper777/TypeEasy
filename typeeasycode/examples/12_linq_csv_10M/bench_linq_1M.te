// Bench LINQ sobre 1M filas (CSV) — TypeEasy v0.0.11
// Cobertura completa: agregaciones + materializadores (where, minBy, maxBy,
// take, orderBy). A 1M filas el container no entra en OOM.
//
// Uso (medir wall-clock con `time`):
//   time docker compose run --rm typeeasy examples/12_linq_csv_10M/bench_linq_1M.te
//
// CSV requerido: /code/productos_1000000.csv (1M filas: nombre,precio).

class Producto {
  nombre : string;
  precio : int;
}

let productos = from "productos_1000000.csv", Producto;
println("filas=" + productos.length);

// --- agregaciones O(n) ---
println("sumBy.precio="   + productos.sumBy(fn(p) => p.precio));
println("avgBy.precio="   + productos.avgBy(fn(p) => p.precio));
println("countWhere>500=" + productos.countWhere(fn(p) => p.precio > 500));
println("countWhere<10="  + productos.countWhere(fn(p) => p.precio < 10));
println("all(precio>=0)=" + productos.all(fn(p)  => p.precio >= 0));
println("none(precio<0)=" + productos.none(fn(p) => p.precio < 0));

// --- materializadores y min/max sobre objetos ---
let baratos = productos.where(fn(p) => p.precio < 10);
println("where<10.length=" + baratos.length);

let mb = productos.minBy(fn(p) => p.precio);
println("minBy=" + mb.nombre + "," + mb.precio);

let mx = productos.maxBy(fn(p) => p.precio);
println("maxBy=" + mx.nombre + "," + mx.precio);

let top5 = productos.take(5);
println("take5.length=" + top5.length);

println("OK");
