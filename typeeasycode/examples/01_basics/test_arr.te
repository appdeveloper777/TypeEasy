// Fase 1a: arrays — literal, indexado, length
var nums = [10, 20, 30];
println(nums[0]);
println(nums[1]);
println(nums[2]);
println(nums.length);

var names = ["Ana", "Luis", "Pedro"];
println(names[0]);
println(names[2]);
println(names.length);

var i = 1;
println(nums[i]);

var total = nums[0] + nums[1] + nums[2];
println(total);

var vacia = [];
println(vacia.length);
