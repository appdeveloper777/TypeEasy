// LINQ where — filtrar por predicado
// Devuelve los elementos para los que el lambda es verdadero.

let nums = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3];

let pares    = nums.where(fn(n) => n % 2 == 0);
let mayores3 = nums.where(fn(n) => n > 3);

println("nums="     + nums.join(","));
println("pares="    + pares.join(","));
println("mayores3=" + mayores3.join(","));
