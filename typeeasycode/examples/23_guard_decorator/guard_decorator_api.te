// =============================================================
// examples/23_guard_decorator — decorador @<nombre> definible por vos
//
// A diferencia de @auth (que valida un JWT Bearer fijo), aquí VOS defines
// la lógica del guard como una función global y la usas como decorador.
//
//   - Defines un guard:  let login = fn() => { ... };
//   - Lo aplicas:        @login  antes del atributo HTTP.
//   - El guard se ejecuta ANTES del handler. Si devuelve un valor
//     FALSY (string vacío "", 0, false, null) -> respuesta automática
//     HTTP 401 {"error":"unauthorized"} y el handler NO se ejecuta.
//   - Si devuelve un valor truthy (string no vacío, número != 0, etc.)
//     -> pasa y el handler corre normalmente.
//
// El nombre del decorador = nombre de la función guard (vos lo creas).
// Esto elimina el boilerplate repetido de:
//     if (sesion == "") { response_status(401); return json("..."); }
//
// Dos formas de proteger TODO un bloque endpoint de una sola vez:
//     @login endpoint { ... }      (decorador ANTES de endpoint)
//     endpoint @login { ... }      (decorador DESPUÉS de endpoint)
// Un decorador per-método dentro del bloque OVERRIDE al del bloque.
//
// -------------------------------------------------------------
// Ejecutar:
//   typeeasy --api examples/23_guard_decorator/guard_decorator_api.te --port 9104
//   # o con Docker:  docker compose up -d typeeasy
//
// Probar:
//   # ruta pública -> 200 sin cookie
//   curl -s http://localhost:9104/api/public
//
//   # ruta protegida sin cookie -> 401 automático
//   curl -s -i http://localhost:9104/api/perfil
//
//   # ruta protegida con cookie de sesión -> 200
//   curl -s --cookie "session=abc123" http://localhost:9104/api/perfil
//
//   # ruta admin: el guard @admin pide role=admin (override del bloque)
//   curl -s -i --cookie "session=abc123" http://localhost:9104/api/admin
//   curl -s --cookie "role=admin" http://localhost:9104/api/admin
// =============================================================

// --- Guards: funciones globales que devuelven truthy=pasa / falsy=401 ---

// Sesión válida si llega la cookie "session" (no vacía).
let login = fn() => {
    let tok = request_cookie("session");
    if (tok == "") { return ""; }   // "" -> 401 automático
    return tok;                      // truthy -> pasa
};

// Rol admin: requiere la cookie role=admin.
let admin = fn() => {
    let r = request_cookie("role");
    if (r == "admin") { return r; }
    return "";
};

// Opcional: el guard puede ELEGIR el código de denegación llamando a
// response_status(N) antes de retornar un valor falsy. Si no lo llama,
// la denegación es 401 por defecto.
//   let soloHorario = fn() => {
//       if (fueraDeHorario()) { response_status(503); return ""; }  // 503
//       return "ok";
//   };

// --- @login endpoint { ... }: el guard protege TODOS los métodos ---
@login endpoint {
    // Pública: anulamos el guard del bloque NO es posible aquí; si querés
    // una ruta pública, ponla en un bloque endpoint aparte (sin decorador).

    // Protegida por @login (heredado del bloque).
    [HttpGet("/api/perfil")]
    perfil() {
        return json("{\"ok\":true,\"area\":\"perfil\"}");
    }

    // Otra protegida por @login, sin repetir nada.
    [HttpGet("/api/dashboard")]
    dashboard() {
        return json("{\"ok\":true,\"area\":\"dashboard\"}");
    }

    // Override per-método: esta pide @admin en vez de @login.
    @admin
    [HttpGet("/api/admin")]
    adminArea() {
        return json("{\"ok\":true,\"area\":\"admin\"}");
    }
}

// --- Bloque público aparte (sin decorador) ---
endpoint {
    [HttpGet("/api/public")]
    publicArea() {
        return json("{\"ok\":true,\"area\":\"public\"}");
    }
}
