class Usuario {
  Id : int;
  usuario : string;
  email : string;
  __constructor(_id : int, _usuario : string, _email : string) {
    this.Id = _id;
    this.usuario = _usuario;
    this.email = _email;
  }
}

println("[STEP 1] start");
string host = "gateway01.us-east-1.prod.aws.tidbcloud.com";
