string pass = "dMal8ex6FlLgprno";
string db   = "test";
int port = 4000;
let conn_id = mysql_connect(host, user, pass, db, port);
println("[STEP 2] connected");
let filtro = new Usuario(1, "O'Reilly Book", "test");
println("[STEP 3] obj created");
