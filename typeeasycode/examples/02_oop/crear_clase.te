/* ***********************
Esta es mi clase DE LOS DIOSES
**************************/
class Person {
    edad : int;  
    nombre : string;
    company : string;
    __constructor(_edad : int, _nombre : string, _company : string) {        
        this.company = _company;                 
        this.edad = _edad;
        this.nombre = _nombre;        
    }
    Imprimir(p_edad : int) : dynamic {
       
        const pi = 3.1416;
        print("EL VALOR DE PI ES: ");
        print(pi);  
        println("MI EDAD ES: ");
        print(this.edad);
        print("MI NOMBRE ES: ");
        print(this.nombre);
        println("MI EMPRESA ES: ");
        println(this.company);
    }  
    
    Saludar() : dynamic {

      int x = 10;
      int y = 5;

      // -------------------------------- Ejemplo de if-else------------------------------------------
      if(x > y) {
          println("x es mayor que y");
      } else {
          println("x es menor o igual que y");
      } 

        string test_local = "hola";
        return test_local;   
    }

    ObtenerEdad() : dynamic {
        float edad_double = 3.4;
        return edad_double;
    }

    Contar() : dynamic {
        int numero = 8 * 3;//2 * 2  / 2 + 1 + 1 + 1 - 1 ;
        return numero;
    }

    // Retorna un string formateado con el nombre
    NombreFormateado() : dynamic {
        string saludo = "Sr/Sra ";
        int prueba = 5;
        return prueba;
    }

    // Retorna el doble de la edad (int)
    EdadDoble() : dynamic {
        int doble = this.edad * 2;
        return doble;
    }
}

int mi_edad = 36;
string mi_nombre = "Fernando Ingunza";
string mi_empresa = "Roussecloud";
let obj = new Person(mi_edad, mi_nombre, mi_empresa);
let persona = new Person(mi_edad, mi_nombre, mi_empresa);

int contarResult = obj.Contar();
string saludarResult1 = persona.Saludar();
string saludarResult2 = obj.Saludar();
var nombreFmt = persona.NombreFormateado();
int edadDoble = obj.EdadDoble();

obj.Imprimir(12);
println(saludarResult1);
println(saludarResult2);
println(contarResult);
println(nombreFmt);
println(edadDoble);

